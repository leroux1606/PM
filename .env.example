# Copy to .env for local Podman Compose (see docs/DEV_CONTAINER.md).
# Never commit real secrets. Keys are injected at runtime, not baked into images.

OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional overrides (defaults match Part 8 / OpenRouter docs).
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openai/gpt-oss-120b

# SQLite file. compose.yaml sets /data/pm.db for the container; omit locally to use backend/data/pm.db.
# PM_DATABASE_PATH=

# Set to true when running behind HTTPS in production (makes the session cookie Secure).
COOKIE_SECURE=false
